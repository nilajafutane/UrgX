<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D1F">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Safe Route"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Auto SOS if you stop moving or go off route"
            android:textSize="13sp"
            android:textColor="#555577"
            android:layout_marginBottom="32dp"/>

        <!-- Status card -->
        <LinearLayout
            android:id="@+id/cardStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A1A2E"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Inactive"
                android:textSize="15sp"
                android:textColor="#555577"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvDestStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No active route"
                android:textSize="13sp"
                android:textColor="#333355"
                android:layout_marginTop="6dp"/>

        </LinearLayout>

        <!-- Destination input -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DESTINATION"
            android:textSize="11sp"
            android:textColor="#444466"
            android:letterSpacing="0.12"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etDestination"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter destination name"
            android:textColorHint="#333355"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:background="#1A1A2E"
            android:padding="16dp"
            android:layout_marginBottom="24dp"
            android:inputType="text"
            android:imeOptions="actionDone"/>

        <!-- Alerts config -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AUTO SOS TRIGGERS"
            android:textSize="11sp"
            android:textColor="#444466"
            android:letterSpacing="0.12"
            android:layout_marginBottom="12dp"/>

        <!-- Trigger cards -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1A1A2E"
            android:padding="16dp"
            android:orientation="horizontal"
            android:layout_marginBottom="2dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="No movement for 5 minutes"
                android:textColor="#CCCCDD" android:textSize="14sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="✓" android:textColor="#00D26A" android:textSize="16sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1A1A2E"
            android:padding="16dp"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="500m off route"
                android:textColor="#CCCCDD" android:textSize="14sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="✓" android:textColor="#00D26A" android:textSize="16sp"/>
        </LinearLayout>

        <!-- Start button -->
        <Button
            android:id="@+id/btnStartRoute"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Start Safe Route"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#E91E63"
            android:layout_marginBottom="12dp"/>

        <!-- Check in button -->
        <Button
            android:id="@+id/btnCheckIn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="I Arrived Safely ✓"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#00D26A"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>